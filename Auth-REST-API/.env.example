# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
DB_PATH=./data/auth.db
# Optional Prisma URL override (if omitted, backend derives this from DB_PATH)
# DATABASE_URL=file:./data/auth.db

# ── Sessions ─────────────────────────────────────────────────────────────────
SESSION_EXPIRY_HOURS=24        # Float — e.g. 0.5 for 30 minutes

# ── Password Reset ────────────────────────────────────────────────────────────
RESET_TOKEN_EXPIRY_MINUTES=60
APP_URL=http://localhost:3000   # Used in reset-password email links

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false               # true for port 465 (SSL)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
BCRYPT_ROUNDS=12                # Higher = slower but stronger. 10-14 recommended

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_GLOBAL=100           # Requests per 15 min per IP (all routes)
RATE_LIMIT_AUTH=20              # Requests per 15 min per IP (auth routes only)
