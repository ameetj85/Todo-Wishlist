{
  "name": "auth-api",
  "version": "1.0.0",
  "description": "Production-ready REST API authentication system with SQLite",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test src/tests/**/*.test.js",
    "test:watch": "node --test --watch src/tests/**/*.test.js",
    "test:coverage": "node --experimental-test-coverage --test src/tests/**/*.test.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "db:init": "node scripts/db-init.js",
    "db:reset": "node scripts/db-reset.js",
    "db:seed": "node scripts/db-seed.js",
    "db:cleanup": "node scripts/db-cleanup.js",
    "check:env": "node scripts/check-env.js"
  },
  "keywords": [
    "auth",
    "authentication",
    "rest-api",
    "express",
    "sqlite",
    "nodejs"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "nodemailer": "^6.9.13",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  }
}
