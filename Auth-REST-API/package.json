{
  "name": "auth-api",
  "version": "1.0.0",
  "description": "Production-ready REST API authentication system with SQLite",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test src/tests/**/*.test.js",
    "test:watch": "node --test --watch src/tests/**/*.test.js",
    "test:coverage": "node --experimental-test-coverage --test src/tests/**/*.test.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "db:init": "node scripts/db-init.js",
    "db:reset": "node scripts/db-reset.js",
    "db:seed": "node scripts/db-seed.js",
    "db:cleanup": "node scripts/db-cleanup.js",
    "check:env": "node scripts/check-env.js"
  },
  "keywords": [
    "auth",
    "authentication",
    "rest-api",
    "express",
    "sqlite",
    "nodejs"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "eslint": "^10.0.3"
  }
}
